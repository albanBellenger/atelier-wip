{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --maxWorkers=1",
    "test:coverage:module": "vitest run --coverage --coverage.reportOnFailure",
    "test:e2e": "playwright test"
  },
  "dependencies": {
