# Copy to .env and adjust. Used by docker compose and local tooling.

JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=

# For docker-compose.yml backend service (optional when running backend on host)
DATABASE_URL=postgresql+asyncpg://atelier:atelier@localhost:5432/atelier

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
