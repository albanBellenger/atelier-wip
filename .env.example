# Copy to .env and adjust. Used by docker compose and local tooling.

JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRE_MINUTES=10080

# Fernet key (url-safe base64 from Fernet.generate_key()) — required to store GitLab tokens on Software.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# For docker-compose.yml backend service (optional when running backend on host)
DATABASE_URL=postgresql+asyncpg://atelier:atelier@localhost:5432/atelier

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend runtime (optional; defaults suit local dev)
# ENV=dev
# SECURE_COOKIES=false

# Set true only on a trusted debug host — never in production
# ATELIER_EXPOSE_INTERNAL_ERRORS=false

# Vite dev proxy when the frontend runs in Docker Compose (set automatically on the frontend service).
# ATELIER_API_PROXY=http://backend:8000

# Production static build: browser-visible API origin (see docs/configuration.md)
# VITE_API_BASE_URL=https://api.example.com
